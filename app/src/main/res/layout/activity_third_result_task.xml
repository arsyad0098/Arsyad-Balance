<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="28dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_leaf"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Leafboard"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2D5A1B" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Beranda Utama"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:fontFamily="@font/inter_italic_variable_font"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat datang kembali!\nApa yang ingin kamu kerjakan hari ini?"
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:fontFamily="@font/inter_italic_variable_font"
            android:layout_marginBottom="28dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_green"
            android:padding="16dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ringkasan Aktivitas"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp">
                    <View
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_green_dark" />
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check_small" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 Proyek sedang berjalan"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#27500A" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp">
                    <View
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_green_dark" />
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check_small" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 Pesan baru belum dibaca"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#27500A" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <Button
                android:id="@+id/btnBangunRuang"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Bangun Ruang"
                android:textColor="#2D5A1B"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#A8E07A"
                app:cornerRadius="50dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnCustom1"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Custom 1"
                android:textColor="#2D5A1B"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#A8E07A"
                app:cornerRadius="50dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnCustom2"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Custom 2"
                android:textColor="#2D5A1B"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#A8E07A"
                app:cornerRadius="50dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnMenuKeluar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Keluar"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#2D5A1B"
                app:cornerRadius="50dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>