<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="28dp"
        android:paddingTop="64dp"
        android:paddingBottom="40dp">

        <!-- Icon Lingkaran Centang -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp">

            <View
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_circle_green" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                android:contentDescription="Success" />
        </FrameLayout>

        <!-- Brand kecil -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_leaf"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Leafboard"
                android:textSize="14sp"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- Judul -->
        <TextView
            android:id="@+id/textView3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat Datang!"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:fontFamily="@font/inter_italic_variable_font"
            android:layout_marginBottom="8dp" />

        <!-- Subjudul -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Akun kamu berhasil dibuat.\nSiap untuk bekerja tanpa batas."
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:fontFamily="@font/inter_italic_variable_font"
            android:layout_marginBottom="28dp" />

        <!-- Card Checklist -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_green"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <!-- Item 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp">
                    <View
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_green_dark" />
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check_small" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email terverifikasi"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#27500A" />
            </LinearLayout>

            <!-- Item 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp">
                    <View
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_green_dark" />
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check_small" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Akun berhasil dibuat"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#27500A" />
            </LinearLayout>

            <!-- Item 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp">
                    <View
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_green_dark" />
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check_small" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Login berhasil"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#27500A" />
            </LinearLayout>

        </LinearLayout>

        <!-- Tombol Mulai -->
        <Button
            android:id="@+id/btnMulai"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Mulai sekarang"
            android:textColor="#2D5A1B"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#A8E07A"
            app:cornerRadius="50dp" />

    </LinearLayout>
</ScrollView>