<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="56dp"
        android:paddingBottom="32dp">

        <!-- Logo + Brand -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_leaf"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Taskly"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:fontFamily="@font/inter_italic_variable_font"/>
        </LinearLayout>

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Work without limits"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="36dp"
            android:fontFamily="@font/inter_italic_variable_font"/>

        <!-- Email Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your email address"
            android:textSize="13sp"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/inter_variable_font"
            android:textStyle="bold"/>

        <!-- Email Input -->
        <EditText
            android:id="@+id/inputEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Unknown@Gmail.Com"
            android:textColorHint="#AAAAAA"
            android:textSize="14sp"
            android:textColor="#1A1A1A"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="20dp"
            android:background="@drawable/bg_input_rounded"
            android:layout_marginBottom="20dp" />


        <!-- Password Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose a password"
            android:textSize="13sp"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/inter_variable_font"
            android:textStyle="bold"/>

        <!-- Password Input Wrapper -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/inputPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="min. 8 characters"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:paddingEnd="52dp"
                android:background="@drawable/bg_input_rounded" />

            <ImageButton
                android:id="@+id/btnTogglePassword"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:src="@drawable/ic_eye"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Toggle password" />
        </FrameLayout>

        <!-- Continue Button -->
        <Button
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Continue"
            android:textColor="#2D5A1B"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#A8E07A"
            android:layout_marginBottom="20dp"
            app:cornerRadius="50dp" />

        <!-- Divider or -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#E0E0E0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="or"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:fontFamily="@font/inter_variable_font"
                android:paddingHorizontal="12dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#E0E0E0" />
        </LinearLayout>

        <!-- Sign up with Google -->
        <Button
            android:id="@+id/btnGoogle"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Sign up with Google"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="50dp"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp"
            app:icon="@drawable/ic_google"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@null"
            app:iconSize="24dp"/>

        <!-- Sign up with Apple -->
        <Button
            android:id="@+id/btnApple"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Sign up with Facebook"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:backgroundTint="#FFFFFF"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="50dp"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp"
            app:icon="@drawable/ic_facebook"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@null"
            app:iconSize="24dp"/>

    </LinearLayout>
</ScrollView>